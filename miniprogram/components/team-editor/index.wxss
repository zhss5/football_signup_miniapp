.team-row {
  margin-bottom: 16rpx;
}

.team-fields {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
}

.team-input {
  flex: 1 1 auto;
  min-width: 0;
  box-sizing: border-box;
  display: block;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.team-capacity {
  flex: 0 0 116rpx;
  text-align: center;
}

.remove-button {
  flex: 0 0 132rpx;
  margin: 0;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  box-sizing: border-box;
}

.add-button {
  margin-top: 8rpx;
}
