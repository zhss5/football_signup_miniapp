.card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.card-embedded {
  margin-bottom: 0;
  border-radius: 0;
}

.cover-frame {
  position: relative;
  width: 100%;
  padding-top: 50%;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.cover-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
}

.meta {
  color: #6b7280;
}

.status {
  color: #6b7280;
  font-weight: 500;
}

.status-joinable {
  color: #168a45;
  font-weight: 700;
}

.status-disabled {
  color: #9ca3af;
}
