.card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.cover-frame {
  position: relative;
  width: 100%;
  padding-top: 50%;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.cover-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
}

.meta,
.status {
  color: #6b7280;
}
