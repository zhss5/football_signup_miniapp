.team-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.team-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.team-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
}

.team-name {
  flex: 0 1 auto;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 700;
}

.team-count {
  flex: 0 0 auto;
}

.member-list {
  margin-bottom: 16rpx;
}

.member-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.member-avatar-image,
.member-avatar-fallback {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.member-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #dcfce7;
  color: #166534;
  font-size: 24rpx;
  font-weight: 700;
}

.member-info {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.member-name-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.member-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 400;
}

.member-proxy-badge {
  flex: 0 0 auto;
  margin-left: 10rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  color: #92400e;
  background: #fef3c7;
  font-size: 20rpx;
  line-height: 32rpx;
  font-weight: 600;
}

.member-position-text {
  display: block;
  margin-top: 4rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 30rpx;
}

.member-action-button {
  flex: 0 0 auto;
  margin-left: 16rpx;
  min-width: 112rpx;
  height: 56rpx;
  line-height: 54rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
  background: #f9fafb;
}

.member-action-button::after {
  border: none;
}

.member-action-move {
  color: #166534;
  background: #f0fdf4;
  border-color: #bbf7d0;
}

.member-action-cancel {
  color: #ffffff;
  background: #ea580c;
  border-color: #ea580c;
  box-shadow: 0 6rpx 14rpx rgba(234, 88, 12, 0.18);
}

.member-action-danger {
  color: #dc2626;
  background: #fef2f2;
  border-color: #fecaca;
}

.empty-members {
  display: block;
  margin-bottom: 16rpx;
  color: #9ca3af;
}

.proxy-signup-button {
  flex: 0 0 auto;
  margin: 0;
  min-width: 132rpx;
  height: 56rpx;
  line-height: 54rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 1rpx solid #bbf7d0;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #166534;
  background: #f0fdf4;
}

.proxy-signup-button::after {
  border: none;
}

.join-button {
  flex: 0 0 auto;
  margin: 0;
  min-width: 104rpx;
  height: 56rpx;
  line-height: 54rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 1rpx solid #16a34a;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  background: #16a34a;
}

.join-button::after {
  border: none;
}
