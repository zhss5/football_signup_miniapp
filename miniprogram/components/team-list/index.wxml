<view class="team-list">
  <block wx:for="{{teams}}" wx:key="_id">
    <view class="team-card">
      <view class="team-head">
        <text>{{item.teamName}}</text>
        <text>{{item.joinedCount}} / {{item.maxMembers}}</text>
      </view>
      <view wx:if="{{item.members.length}}" class="member-list">
        <block wx:for="{{item.members}}" wx:key="userOpenId" wx:for-item="member">
          <view class="member-row">
            <image wx:if="{{member.avatarUrl}}" class="member-avatar-image" src="{{member.avatarUrl}}" mode="aspectFill" />
            <view wx:else class="member-avatar-fallback">{{member.avatarText}}</view>
            <view class="member-info">
              <text class="member-name">{{member.signupName}}</text>
              <text wx:if="{{member.proxyBadgeVisible}}" class="member-proxy-badge">{{member.proxyBadgeText}}</text>
            </view>
            <button
              wx:if="{{member.memberAction}}"
              class="member-action-button {{member.memberAction === 'cancelSignup' ? 'member-action-cancel' : ''}} {{member.memberAction === 'remove' ? 'member-action-danger' : ''}}"
              size="mini"
              data-action="{{member.memberAction}}"
              data-user-open-id="{{member.userOpenId}}"
              data-signup-name="{{member.signupName}}"
              catchtap="onMemberActionTap"
            >{{member.memberActionText}}</button>
          </view>
        </block>
      </view>
      <text wx:else class="empty-members">{{emptyText}}</text>
      <button
        wx:if="{{item.canProxySignup}}"
        class="proxy-signup-button"
        data-team-id="{{item._id}}"
        data-team-name="{{item.teamName}}"
        bindtap="onProxySignupTap"
      >{{item.proxySignupText}}</button>
      <button data-team-id="{{item._id}}" bindtap="onJoinTap" disabled="{{item.joinDisabled}}">{{item.joinButtonText}}</button>
    </view>
  </block>
</view>
