<view class="page">
  <view class="utility-row">
    <text class="utility-label">{{i18n.my.languageLabel}}</text>
    <block wx:for="{{languageOptions}}" wx:key="key">
      <button
        size="mini"
        class="utility-chip {{locale === item.key ? 'utility-chip-active' : ''}}"
        data-locale="{{item.key}}"
        bindtap="onLanguageChange"
      >
        {{item.label}}
      </button>
    </block>
  </view>

  <view wx:if="{{userOpenId}}" class="identity-card">
    <text class="identity-label">{{i18n.my.userIdLabel}}</text>
    <view class="identity-row">
      <text class="identity-value">{{userOpenId}}</text>
      <button size="mini" class="utility-chip" bindtap="onCopyUserId">{{i18n.my.copyUserId}}</button>
    </view>
    <text class="identity-role">{{i18n.my.roleLabel}} {{userRoleText}}</text>
  </view>

  <view class="primary-tab-shell">
    <block wx:for="{{tabs}}" wx:key="key">
      <button
        size="mini"
        class="primary-tab-chip {{activeTab === item.key ? 'primary-tab-chip-active' : ''}}"
        data-tab-key="{{item.key}}"
        bindtap="onTabChange"
      >
        {{item.label}}
      </button>
    </block>
  </view>

  <view wx:if="{{activeTab === 'created'}}" class="section">
    <view class="filter-group">
      <text class="filter-heading">{{filterLabel}}</text>
      <view class="filter-row">
        <block wx:for="{{createdFilters}}" wx:key="key">
          <button
            size="mini"
            class="filter-chip {{createdFilter === item.key ? 'filter-chip-active' : ''}}"
            data-filter-key="{{item.key}}"
            bindtap="onCreatedFilterTap"
          >
            {{item.label}}
          </button>
        </block>
      </view>
    </view>
    <block wx:for="{{createdItems}}" wx:key="_id">
      <view class="activity-item">
        <activity-card item="{{item}}" bind:tapcard="goDetail" />
        <view class="action-row">
          <button
            wx:if="{{item.canCancelActivity}}"
            size="mini"
            data-activity-id="{{item._id}}"
            catchtap="onCancelActivity"
          >
            {{i18n.activity.actions.cancelActivity}}
          </button>
          <button
            wx:if="{{item.canDeleteActivity}}"
            size="mini"
            data-activity-id="{{item._id}}"
            catchtap="onDeleteActivity"
          >
            {{i18n.activity.actions.delete}}
          </button>
        </view>
      </view>
    </block>
  </view>

  <view wx:elif="{{activeTab === 'joined'}}" class="section">
    <block wx:for="{{joinedItems}}" wx:key="_id">
      <activity-card item="{{item}}" bind:tapcard="goDetail" />
    </block>
  </view>
</view>
