.page {
  padding: 24rpx;
}

.tab-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tab-chip {
  min-width: 160rpx;
  background: #ffffff;
  color: #374151;
}

.tab-chip-active {
  background: #111827;
  color: #ffffff;
}

.section {
  margin-bottom: 32rpx;
}

.activity-item {
  margin-bottom: 20rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.filter-chip {
  min-width: 120rpx;
  background: #ffffff;
  color: #374151;
}

.filter-chip-active {
  background: #111827;
  color: #ffffff;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: -4rpx;
  margin-bottom: 4rpx;
}
