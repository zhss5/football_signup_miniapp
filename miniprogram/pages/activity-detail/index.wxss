.page {
  padding: 24rpx;
}

.hero {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.cover-frame {
  position: relative;
  width: 100%;
  padding-top: 50%;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.cover-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.share-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.share-card-highlight {
  border: 2rpx solid #16a34a;
  box-shadow: 0 8rpx 24rpx rgba(22, 163, 74, 0.12);
}

.share-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.share-copy {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.share-button {
  margin-top: 16rpx;
  background: #16a34a;
  color: #ffffff;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.meta {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
}

.location-row {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.location {
  flex: 1;
  min-width: 0;
  padding: 4rpx 0;
}

.location-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  word-break: break-word;
}

.location-map {
  flex: 0 0 168rpx;
  width: 168rpx;
  height: 112rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
