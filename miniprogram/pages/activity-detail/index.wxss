.page {
  padding: 24rpx;
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
}

.hero {
  padding: 24rpx;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  overflow: hidden;
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.cover-frame {
  position: relative;
  width: 100%;
  padding-top: 50%;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.cover-image,
.cover-placeholder {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
}

.share-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.share-card-highlight {
  border: 2rpx solid #16a34a;
  box-shadow: 0 8rpx 24rpx rgba(22, 163, 74, 0.12);
}

.insurance-link-button {
  display: block;
  width: auto;
  margin: 0 0 18rpx;
  padding: 0;
  background: transparent;
  color: #0f766e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: left;
}

.insurance-link-button::after {
  border: 0;
}

.share-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.share-copy {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.share-button {
  margin-top: 16rpx;
  background: #16a34a;
  color: #ffffff;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.meta {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
}

.location-row {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
  align-items: stretch;
  max-width: 100%;
  overflow: hidden;
}

.location {
  flex: 1;
  min-width: 0;
  padding: 4rpx 0;
}

.location-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  word-break: break-word;
}

.location-map-wrap {
  position: relative;
  flex: 0 0 168rpx;
  display: block;
  width: 168rpx;
  max-width: 168rpx;
  height: 112rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  overflow: hidden;
}

.location-map {
  width: 100%;
  height: 100%;
  max-width: 100%;
}

.location-map-hitarea {
  position: absolute;
  left: 0;
  top: 0;
  width: 168rpx;
  max-width: 168rpx;
  height: 112rpx;
  box-sizing: border-box;
}

.confirmed-banner {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #166534;
  font-size: 24rpx;
  font-weight: 700;
}

.action-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-button {
  width: 100%;
  margin: 0;
  color: #111827;
  background: #ffffff;
}

.danger-action-button {
  color: #b91c1c;
}

.confirm-action-button {
  color: #166534;
  background: #ecfdf5;
}
