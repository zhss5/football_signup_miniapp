<view class="page" wx:if="{{activity}}">
  <view class="hero">
    <view wx:if="{{activity.coverDisplayImage || activity.coverImage}}" class="cover-frame">
      <image wx:if="{{activity.coverDisplayImage}}" class="cover-image" src="{{activity.coverDisplayImage}}" mode="aspectFill" />
      <view wx:else class="cover-placeholder"></view>
    </view>
    <text class="title">{{activity.title}}</text>
    <view class="location-row">
      <view class="location" bindtap="onOpenLocation">
        <text class="location-name">{{activity.addressName || activity.addressText}}</text>
        <text wx:if="{{activity.addressName && activity.addressName !== activity.addressText}}" class="meta">{{activity.addressText}}</text>
      </view>
      <view wx:if="{{locationMapVisible}}" class="location-map-wrap">
        <map
          class="location-map"
          latitude="{{activity.location.latitude}}"
          longitude="{{activity.location.longitude}}"
          markers="{{locationMapMarkers}}"
          scale="15"
          enable-scroll="{{false}}"
          enable-zoom="{{false}}"
          enable-rotate="{{false}}"
          show-location="{{false}}"
          bindmarkertap="onOpenLocation"
          bindtap="onOpenLocation"
        >
          <cover-view class="location-map-hitarea" bindtap="onOpenLocation"></cover-view>
        </map>
      </view>
    </view>
  </view>

  <view wx:if="{{activity.status === 'published'}}" class="share-card {{shareHintVisible ? 'share-card-highlight' : ''}}">
    <text class="share-title">{{shareHintVisible ? i18n.activity.share.publishedTitle : i18n.activity.share.defaultTitle}}</text>
    <text class="share-copy">{{shareHintVisible ? i18n.activity.share.publishedCopy : i18n.activity.share.defaultCopy}}</text>
    <button class="share-button" open-type="share">{{i18n.activity.share.action}}</button>
  </view>

  <team-list
    teams="{{teams}}"
    emptyText="{{i18n.activity.teamList.empty}}"
    bind:jointap="openSignup"
    bind:removemember="onRemoveRegistration"
    bind:cancelsignup="onCancelSignup"
  />

  <view wx:if="{{viewer && (viewer.canManageRegistrations || viewer.canEditActivity || viewer.canCancelActivity)}}" class="action-panel">
    <button wx:if="{{viewer.canManageRegistrations}}" class="action-button" bindtap="onCopyParticipantNames">
      {{i18n.activity.actions.copyParticipantNames}}
    </button>

    <button wx:if="{{viewer.canEditActivity}}" class="action-button" bindtap="openEditActivity">
      {{i18n.activity.actions.edit}}
    </button>

    <button wx:if="{{viewer.canCancelActivity}}" class="action-button danger-action-button" bindtap="onCancelActivity">
      {{i18n.activity.actions.cancelActivity}}
    </button>
  </view>

</view>
