.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.crop-shell {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.hint {
  display: block;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.image-stage {
  position: relative;
  width: 100%;
  height: 720rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #111827;
}

.stage-image {
  position: absolute;
  transform-origin: top left;
}

.stage-mask {
  position: absolute;
  background: rgba(17, 24, 39, 0.55);
  pointer-events: none;
}

.selection-frame {
  position: absolute;
  border-radius: 24rpx;
  overflow: hidden;
  pointer-events: none;
}

.selection-frame-outline {
  position: absolute;
  inset: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 24rpx;
  box-sizing: border-box;
}

.control {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.control-label {
  display: block;
  margin-bottom: 12rpx;
  color: #374151;
  font-size: 26rpx;
  font-weight: 600;
}

.secondary-button {
  background: #f9fafb;
  color: #374151;
}

.loading-state {
  color: #6b7280;
  font-size: 26rpx;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}
