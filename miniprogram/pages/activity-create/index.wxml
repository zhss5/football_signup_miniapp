<view class="page">
  <view wx:if="{{!authorizationChecked}}" class="authorization-panel">
    <text class="authorization-title">{{i18n.activityCreate.permissionChecking}}</text>
  </view>

  <view wx:elif="{{!canCreateActivity}}" class="authorization-panel">
    <text class="authorization-title">{{i18n.activityCreate.noCreatePermissionTitle}}</text>
    <text class="hint">{{i18n.activityCreate.noCreatePermissionHint}}</text>
  </view>

  <block wx:else>
  <view class="field">
    <text class="label">{{i18n.activityCreate.title}}</text>
    <input
      class="input"
      placeholder="{{i18n.activityCreate.title}}"
      data-field="title"
      value="{{form.title}}"
      bindinput="onFieldInput"
    />
  </view>

  <view class="field">
    <text class="label">{{i18n.activityCreate.activityDate}}</text>
    <picker mode="date" value="{{form.activityDate}}" data-field="activityDate" bindchange="onPickerChange">
      <view class="picker-input">{{form.activityDate}}</view>
    </picker>
  </view>

  <view class="field">
    <text class="label">{{i18n.activityCreate.activityTime}}</text>
    <view class="picker-grid">
      <view class="picker-cell">
        <text class="sub-label">{{i18n.activityCreate.startTime}}</text>
        <picker mode="time" value="{{form.startTime}}" data-field="startTime" bindchange="onPickerChange">
          <view class="picker-input">{{form.startTime}}</view>
        </picker>
      </view>
      <view class="picker-cell">
        <text class="sub-label">{{i18n.activityCreate.endTime}}</text>
        <picker mode="time" value="{{form.endTime}}" data-field="endTime" bindchange="onPickerChange">
          <view class="picker-input">{{form.endTime}}</view>
        </picker>
      </view>
    </view>
  </view>

  <view class="field">
    <text class="label">{{i18n.activityCreate.signupDeadline}}</text>
    <view class="picker-grid">
      <view class="picker-cell">
        <text class="sub-label">{{i18n.activityCreate.deadlineDate}}</text>
        <picker mode="date" value="{{form.signupDeadlineDate}}" data-field="signupDeadlineDate" bindchange="onPickerChange">
          <view class="picker-input">{{form.signupDeadlineDate}}</view>
        </picker>
      </view>
      <view class="picker-cell">
        <text class="sub-label">{{i18n.activityCreate.deadlineTime}}</text>
        <picker mode="time" value="{{form.signupDeadlineTime}}" data-field="signupDeadlineTime" bindchange="onPickerChange">
          <view class="picker-input">{{form.signupDeadlineTime}}</view>
        </picker>
      </view>
    </view>
    <text class="hint">{{i18n.activityCreate.deadlineHint}}</text>
  </view>

  <view class="field">
    <text class="label">{{i18n.activityCreate.inviteCode}}</text>
    <input
      class="input"
      placeholder="{{i18n.activityCreate.inviteCodePlaceholder}}"
      data-field="inviteCode"
      value="{{form.inviteCode}}"
      bindinput="onFieldInput"
    />
  </view>

  <view class="field">
    <text class="label">{{i18n.activityCreate.teams}}</text>
    <text class="hint">{{i18n.activityCreate.teamsHint}}</text>
  </view>
  <team-editor teams="{{form.teams}}" labels="{{teamEditorLabels}}" bind:change="onTeamsChange" />

  <view class="field">
    <text class="label">{{i18n.activityCreate.totalSignupLimit}}</text>
    <input
      class="input"
      placeholder="{{i18n.activityCreate.totalSignupLimitPlaceholder}}"
      type="number"
      data-field="signupLimitTotal"
      value="{{form.signupLimitTotal}}"
      bindinput="onFieldInput"
    />
    <text class="hint">{{namedTeamsSlotsText}}</text>
    <text wx:if="{{benchSlots > 0}}" class="hint">{{benchSlotsText}}</text>
    <text wx:if="{{overCapacity}}" class="error-text">{{i18n.activityCreate.overCapacity}}</text>
  </view>

  <view class="field">
    <text class="label">{{i18n.activityCreate.requirePhone}}</text>
    <switch checked="{{form.requirePhone}}" bindchange="onRequirePhoneChange" />
  </view>

  <view class="field">
    <text class="label">{{i18n.activityCreate.description}}</text>
    <textarea
      class="textarea"
      placeholder="{{i18n.activityCreate.descriptionPlaceholder}}"
      data-field="description"
      value="{{form.description}}"
      bindinput="onFieldInput"
    />
  </view>

  <view class="field">
    <text class="label">{{i18n.activityCreate.activityImage}}</text>
    <view class="upload-panel">
      <view class="image-preview-frame">
        <image wx:if="{{form.coverImage}}" class="image-preview" src="{{form.coverImage}}" mode="aspectFill" />
        <view wx:else class="upload-placeholder">+</view>
      </view>
      <button class="secondary-button" bindtap="onChooseActivityImage">{{form.coverImage ? i18n.activityCreate.replaceImage : i18n.activityCreate.chooseAndCropImage}}</button>
      <button wx:if="{{form.coverImage}}" class="ghost-button" bindtap="onRemoveActivityImage">{{i18n.activityCreate.removeImage}}</button>
      <text class="hint">{{imageHintText}}</text>
    </view>
  </view>

  <view class="field">
    <text class="label">{{i18n.activityCreate.location}}</text>
    <input
      class="input {{validationErrors.addressText ? 'input-error' : ''}}"
      placeholder="{{i18n.activityCreate.addressPlaceholder}}"
      data-field="addressText"
      value="{{form.addressText}}"
      bindinput="onFieldInput"
    />
    <text wx:if="{{validationErrors.addressText}}" class="error-text">{{validationErrors.addressText}}</text>
    <text wx:if="{{selectedPinText}}" class="hint">{{selectedPinText}}</text>
    <button class="secondary-button" bindtap="onChooseLocation">{{i18n.activityCreate.chooseOnMap}}</button>
  </view>

  <button bindtap="onSubmit" loading="{{submitting}}">{{i18n.activityCreate.publish}}</button>
  </block>
</view>
