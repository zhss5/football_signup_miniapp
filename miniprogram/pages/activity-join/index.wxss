.page {
  padding: 24rpx;
}

.panel {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.hint {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.field {
  margin-top: 24rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #374151;
  font-size: 26rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #f9fafb;
}

.confirm-button {
  margin-top: 28rpx;
}
