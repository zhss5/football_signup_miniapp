.page {
  padding: 24rpx;
}

.panel {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.hint {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.field {
  margin-top: 24rpx;
}

.profile-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 28rpx;
}

.avatar-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  padding: 0;
  margin: 0;
  border-radius: 56rpx;
  background: #eef2f7;
  overflow: hidden;
}

.avatar-button::after {
  border: 0;
}

.avatar-image {
  width: 112rpx;
  height: 112rpx;
}

.avatar-placeholder {
  color: #64748b;
  font-size: 22rpx;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #374151;
  font-size: 26rpx;
  font-weight: 600;
}

.small-hint {
  margin-top: 6rpx;
  font-size: 22rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #f9fafb;
}

.position-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.position-option {
  flex: 0 0 auto;
  min-width: 124rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 32rpx;
  color: #374151;
  background: #f9fafb;
  font-size: 24rpx;
}

.position-option-selected {
  color: #166534;
  background: #dcfce7;
  font-weight: 700;
}

.confirm-button {
  margin-top: 28rpx;
}
